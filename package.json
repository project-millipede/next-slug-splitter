{
  "name": "next-slug-splitter",
  "version": "0.5.0",
  "type": "module",
  "description": "Build-time Next.js route handler generation and rewrite integration for large content trees.",
  "files": [
    "dist"
  ],
  "main": "./dist/next/index.js",
  "module": "./dist/next/index.js",
  "types": "./dist/next/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "default": "./dist/next/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "default": "./dist/next/index.js"
    },
    "./next/config": {
      "types": "./dist/next/config.d.ts",
      "import": "./dist/next/config.js",
      "default": "./dist/next/config.js"
    },
    "./next/adapter": {
      "types": "./dist/next/adapter.d.ts",
      "import": "./dist/next/adapter.js",
      "default": "./dist/next/adapter.js"
    },
    "./next/lookup": {
      "types": "./dist/next/lookup.d.ts",
      "import": "./dist/next/lookup.js",
      "default": "./dist/next/lookup.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "default": "./dist/cli.js"
    }
  },
  "bin": {
    "next-slug-splitter": "./dist/cli.js"
  },
  "keywords": [
    "nextjs",
    "route-handlers",
    "dynamic-routes",
    "content-routing",
    "mdx",
    "rewrites",
    "build-time",
    "static-generation",
    "locale-routing",
    "route-generation"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --environment node",
    "test:watch": "vitest --environment node",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
    "@mdx-js/esbuild": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "esbuild": "0.27.3",
    "fast-glob": "^3.3.2",
    "recma-component-resolver": "0.5.0",
    "ts-morph": "^27.0.2"
  },
  "peerDependencies": {
    "next": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "next": "16.0.0",
    "tsup": "^8.5.0",
    "typescript": "6.0.0-beta",
    "unified": "^11.0.5",
    "vitest": "^3.2.4"
  }
}
