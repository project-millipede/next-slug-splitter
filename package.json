{
  "name": "next-slug-splitter",
  "version": "3.0.0",
  "type": "module",
  "description": "Build-time Next.js route handler generation and rewrite integration for large content trees.",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --environment node",
    "test:watch": "vitest --environment node",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "analyze:turbo": "pnpm next experimental-analyze"
  },
  "dependencies": {
    "@cacheable/utils": "^2.4.1",
    "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
    "@mdx-js/esbuild": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "esbuild": "^0.28.0",
    "fast-glob": "^3.3.2",
    "file-entry-cache": "^11.1.2",
    "recma-component-resolver": "^0.5.1",
    "ts-morph": "^27.0.2",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "next": "^16.2.0",
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "memfs": "^4.57.1",
    "next": "16.2.0",
    "react": "^19.2.4",
    "tsup": "^8.5.0",
    "typescript": "6.0.2",
    "vitest": "4.1.1"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.1"
    }
  },
  "main": "./dist/next/index.js",
  "module": "./dist/next/index.js",
  "types": "./dist/next/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "default": "./dist/next/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "default": "./dist/next/index.js"
    },
    "./next/config": {
      "types": "./dist/next/config.d.ts",
      "import": "./dist/next/config.js",
      "default": "./dist/next/config.js"
    },
    "./next/adapter": {
      "types": "./dist/next/adapter.d.ts",
      "import": "./dist/next/adapter.js",
      "default": "./dist/next/adapter.js"
    },
    "./next/instrumentation": {
      "types": "./dist/next/instrumentation.d.ts",
      "import": "./dist/next/instrumentation.js",
      "default": "./dist/next/instrumentation.js"
    },
    "./next/lookup": {
      "types": "./dist/next/lookup.d.ts",
      "import": "./dist/next/lookup.js",
      "default": "./dist/next/lookup.js"
    },
    "./next/handler": {
      "types": "./dist/next/handler.d.ts",
      "import": "./dist/next/handler.js",
      "default": "./dist/next/handler.js"
    },
    "./next/page-data-compiler": {
      "types": "./dist/next/page-data-compiler.d.ts",
      "import": "./dist/next/page-data-compiler.js",
      "default": "./dist/next/page-data-compiler.js"
    },
    "./next/proxy": {
      "types": "./dist/next/proxy.d.ts",
      "import": "./dist/next/proxy.js",
      "default": "./dist/next/proxy.js"
    },
    "./next/not-found-retry": {
      "types": "./dist/next/not-found-retry.d.ts",
      "import": "./dist/next/not-found-retry.js",
      "default": "./dist/next/not-found-retry.js"
    },
    "./module-reference": {
      "types": "./dist/module-reference/index.d.ts",
      "import": "./dist/module-reference/index.js",
      "default": "./dist/module-reference/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "default": "./dist/cli.js"
    }
  },
  "bin": {
    "next-slug-splitter": "./dist/cli.js"
  },
  "keywords": [
    "nextjs",
    "route-handlers",
    "dynamic-routes",
    "content-routing",
    "mdx",
    "rewrites",
    "build-time",
    "static-generation",
    "locale-routing",
    "route-generation"
  ]
}
