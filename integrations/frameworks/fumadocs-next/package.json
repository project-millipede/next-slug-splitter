{
  "name": "next-slug-splitter-fumadocs-integration",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf .next .source dist app/docs/generated-handlers",
    "clean:handlers": "rimraf app/docs/generated-handlers",
    "generate:ballast": "pnpm --filter @next-slug-splitter/ballast-kit generate",
    "dev": "pnpm clean:handlers && pnpm generate:ballast && next dev",
    "build": "pnpm clean:handlers && pnpm generate:ballast && next build",
    "start": "next start",
    "typecheck": "pnpm clean && pnpm generate:ballast && next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@next-slug-splitter/ballast-kit": "workspace:*",
    "fumadocs-core": "^16.11.5",
    "fumadocs-mdx": "^15.2.0",
    "fumadocs-ui": "^16.11.5",
    "next": "^16.2.11",
    "next-slug-splitter": "file:../../..",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3"
  }
}
